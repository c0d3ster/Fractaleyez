{
  "compilerOptions": {
    // Output — babel handles transpilation, tsc is type-check only
    "noEmit": true,
    "allowJs": true,

    // Language
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],

    // JSX
    "jsx": "react",

    // Strict
    "strict": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true,

    // Interop
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // Paths — baseUrl deprecated in TS 6, use rootDir instead
    "rootDir": "."
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "public"]
}
